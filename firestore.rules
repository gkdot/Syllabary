rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      // prevent clients from writing tokens or changing createdAt
      function noSecrets() {
        return !request.resource.data.keys().hasAny(["accessToken", "refreshToken"]);
      }

      allow create: if request.auth != null
                     && request.resource.data.uid == request.auth.uid
                     && request.resource.data.providers is list
                     && noSecrets();

      allow read: if isOwner();

      allow update: if isOwner()
                    && noSecrets()
                    // prevent changing createdAt once set (optional)
                    && (resource.data.createdAt == null || request.resource.data.createdAt == resource.data.createdAt);

      allow delete: if isOwner();
    }
  }
}
